{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remote Terminal Cloud Agent",
  "version": "0.3.2",
  "identifier": "com.remote-terminal-cloud.agent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Remote Terminal Cloud Agent",
        "width": 1240,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "template": "nsis/installer.nsi"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
