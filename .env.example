RTC_SERVER_BASE_URL=http://127.0.0.1:10001
RTC_REGISTRATION_TOKEN=dev-registration-token
# Optional: system-default | cmd | powershell | pwsh | bash | zsh | sh
RTC_DEFAULT_SHELL=system-default
# Optional: comma-separated allowlist pushed to server after Agent detection, e.g. system-default,powershell,pwsh
RTC_ENABLED_SHELLS=system-default,cmd,powershell,pwsh
# Set to 1 to disable heartbeat during quick smoke tests
RTC_DISABLE_HEARTBEAT=0
# Set to 1 to disable websocket tunnel during quick smoke tests
RTC_DISABLE_TUNNEL=0