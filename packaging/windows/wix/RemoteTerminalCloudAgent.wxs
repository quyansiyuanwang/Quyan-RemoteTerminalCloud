<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="Remote Terminal Cloud Agent"
    Manufacturer="Remote Terminal Cloud"
    Version="0.5.2"
    UpgradeCode="A7A32B15-4E12-4DAB-8B9A-3C91F275AE60"
    InstallerVersion="500"
    Scope="perMachine"
    Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Remote Terminal Cloud Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_Minimal" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Remote Terminal Cloud Agent">
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="Remote Terminal Cloud Agent" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="PROGRAMDATA_AGENT" Name="RemoteTerminalCloudAgent">
        <Directory Id="PROGRAMDATA_AGENT_LOGS" Name="logs" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Remote Terminal Cloud Agent" Level="1">
      <ComponentGroupRef Id="AgentFiles" />
      <ComponentRef Id="ProgramDataDirectoryComponent" />
      <ComponentRef Id="ProgramDataConfigComponent" />
      <ComponentRef Id="ProgramDataLogsDirectoryComponent" />
      <ComponentRef Id="StartMenuShortcutsComponent" />
    </Feature>

    <ComponentGroup Id="AgentFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.AgentBuildRoot)\bin\rtc-agent.exe" />
      <Files Include="$(var.AgentBuildRoot)\bin\rtc-agent-manager.exe" />
      <Files Include="$(var.AgentBuildRoot)\bin\rtc-agent-desktop.exe" />
      <Files Include="$(var.AgentBuildRoot)\bin\rtc-agent-installer.exe" />
    </ComponentGroup>

    <Component Id="ProgramDataDirectoryComponent" Directory="PROGRAMDATA_AGENT" Guid="E5D1A49D-ED8A-43E6-B70A-171D362BF04D">
      <CreateFolder />
    </Component>

    <Component Id="ProgramDataConfigComponent" Directory="PROGRAMDATA_AGENT" Guid="A0DF38D1-6925-4553-8E83-4C6774B664A7">
      <File Id="ProgramDataConfigFile" Source="$(var.AgentBuildRoot)\packaging\windows\agent.config.json" Name="config.json" KeyPath="yes" />
    </Component>

    <Component Id="ProgramDataLogsDirectoryComponent" Directory="PROGRAMDATA_AGENT_LOGS" Guid="2D4D1C5C-111D-4F93-B680-85BA6C4CE355">
      <CreateFolder />
    </Component>

    <Component Id="StartMenuShortcutsComponent" Directory="ProgramMenuDir" Guid="E17EFA2E-DBE4-4950-9BC1-878C20A9A0AF">
      <Shortcut Id="DesktopManagerShortcut"
        Name="Remote Terminal Cloud Agent"
        Target="[INSTALLFOLDER]bin\rtc-agent-desktop.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="DesktopConfigureShortcut"
        Name="Configure Token"
        Target="[INSTALLFOLDER]bin\rtc-agent-desktop.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="OpenConfigDirShortcut"
        Name="Open Config Folder"
        Target="[INSTALLFOLDER]bin\rtc-agent-installer.exe"
        Arguments='windows open-config-dir'
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="OpenLogsShortcut"
        Name="Open Logs"
        Target="[INSTALLFOLDER]bin\rtc-agent-installer.exe"
        Arguments='windows open-logs'
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\RemoteTerminalCloudAgent" Name="StartMenuShortcuts" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Remote Terminal Cloud Agent" />

    <CustomAction Id="LaunchDesktopManager"
      Directory="INSTALLFOLDER"
      Execute="immediate"
      Impersonate="yes"
      Return="asyncNoWait"
      ExeCommand="&quot;[INSTALLFOLDER]bin\rtc-agent-desktop.exe&quot;" />

    <CustomAction Id="InitConfig" Directory="INSTALLFOLDER"
      Execute="deferred" Impersonate="no" Return="check"
      ExeCommand="&quot;[INSTALLFOLDER]bin\rtc-agent-installer.exe&quot; windows init-config" />

    <InstallExecuteSequence>
      <Custom Action="InitConfig" After="InstallFiles" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <InstallUISequence>
      <Custom Action="LaunchDesktopManager" After="ExecuteAction" Condition="NOT Installed AND WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1" />
    </InstallUISequence>

  </Package>
</Wix>
