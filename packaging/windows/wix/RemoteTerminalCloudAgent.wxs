<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Remote Terminal Cloud Agent"
    Manufacturer="Remote Terminal Cloud"
    Version="0.2.0"
    UpgradeCode="A7A32B15-4E12-4DAB-8B9A-3C91F275AE60"
    InstallerVersion="500"
    Scope="perMachine"
    Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Remote Terminal Cloud Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <UIRef Id="WixUI_Minimal" />

    <!-- Inject AgentConfigDlg between LicenseAgreementDlg and VerifyReadyDlg -->
    <UI>
      <Dialog Id="AgentConfigDlg" Width="370" Height="270" Title="[ProductName] Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="yes" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Agent Configuration" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="300" Height="15" Transparent="yes" NoPrefix="yes" Text="Enter the registration token for this device." />

        <Control Id="RegTokenLabel" Type="Text" X="25" Y="84" Width="320" Height="10" Text="Registration &amp;Token (optional):" />
        <Control Id="RegTokenEdit" Type="Edit" X="25" Y="96" Width="320" Height="18" Property="RTC_REG_TOKEN" Password="yes" />
        <Control Id="RegTokenHint" Type="Text" X="25" Y="117" Width="320" Height="18" Transparent="yes"
                 Text="{\WixUI_Font_Smaller}Obtain from your server's admin panel. Can be set later in config.json." />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="248" Width="56" Height="17" Text="&amp;Back">
          <Publish Event="NewDialog" Value="LicenseAgreementDlg">1</Publish>
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="248" Width="56" Height="17" Default="yes" Text="&amp;Next">
          <Publish Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="248" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- Override WixUI_Minimal: EULA Next → AgentConfigDlg instead of VerifyReadyDlg -->
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="AgentConfigDlg" Order="2">LicenseAccepted = "1"</Publish>
      <!-- Override WixUI_Minimal: VerifyReadyDlg Back → AgentConfigDlg on fresh install -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="AgentConfigDlg" Order="2">NOT Installed</Publish>
    </UI>

    <Property Id="RTC_REG_TOKEN" Secure="yes" Hidden="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Remote Terminal Cloud Agent">
        <Directory Id="SERVICEFOLDER" Name="service" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="Remote Terminal Cloud Agent" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="PROGRAMDATA_AGENT" Name="RemoteTerminalCloudAgent">
        <Directory Id="PROGRAMDATA_AGENT_LOGS" Name="logs" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Remote Terminal Cloud Agent" Level="1">
      <ComponentGroupRef Id="AgentFiles" />
      <ComponentRef Id="ProgramDataDirectoryComponent" />
      <ComponentRef Id="ProgramDataConfigComponent" />
      <ComponentRef Id="ProgramDataLogsDirectoryComponent" />
      <ComponentRef Id="ServiceWrapperComponent" />
      <ComponentRef Id="StartMenuShortcutsComponent" />
    </Feature>

    <ComponentGroup Id="AgentFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.AgentBuildRoot)\bin\rtc-agent.exe" />
      <Files Include="$(var.AgentBuildRoot)\bin\rtc-agent-manager.exe" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\install-service.ps1" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\uninstall-service.ps1" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\stop-service.ps1" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\manage-agent.ps1" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\write-config.ps1" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\init-config.ps1" />
    </ComponentGroup>

    <Component Id="ProgramDataDirectoryComponent" Directory="PROGRAMDATA_AGENT" Guid="E5D1A49D-ED8A-43E6-B70A-171D362BF04D">
      <CreateFolder />
    </Component>

    <Component Id="ProgramDataConfigComponent" Directory="PROGRAMDATA_AGENT" Guid="A0DF38D1-6925-4553-8E83-4C6774B664A7">
      <File Id="ProgramDataConfigFile" Source="$(var.AgentBuildRoot)\packaging\windows\agent.config.json" Name="config.json" KeyPath="yes" />
    </Component>

    <Component Id="ProgramDataLogsDirectoryComponent" Directory="PROGRAMDATA_AGENT_LOGS" Guid="2D4D1C5C-111D-4F93-B680-85BA6C4CE355">
      <CreateFolder />
    </Component>

    <Component Id="ServiceWrapperComponent" Directory="SERVICEFOLDER" Guid="A9D91CF9-43F6-4227-934B-988D53A4887D">
      <File Id="RemoteTerminalCloudAgentServiceExe" Source="$(var.AgentBuildRoot)\service\RemoteTerminalCloudAgentService.exe" KeyPath="yes" />
      <File Id="RemoteTerminalCloudAgentServiceXml" Source="$(var.AgentBuildRoot)\service\RemoteTerminalCloudAgentService.xml" />
    </Component>

    <Component Id="StartMenuShortcutsComponent" Directory="ProgramMenuDir" Guid="E17EFA2E-DBE4-4950-9BC1-878C20A9A0AF">
      <Shortcut Id="AgentManagerShortcut"
        Name="Agent Manager"
        Target="[INSTALLFOLDER]bin\rtc-agent-manager.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="ConfigureAgentShortcut"
        Name="Configure Agent"
        Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
        Arguments='-NoExit -ExecutionPolicy Bypass -File "[INSTALLFOLDER]manage-agent.ps1" configure'
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="OpenConfigDirShortcut"
        Name="Open Config Folder"
        Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
        Arguments='-ExecutionPolicy Bypass -File "[INSTALLFOLDER]manage-agent.ps1" open-config-dir'
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="OpenLogsShortcut"
        Name="Open Logs"
        Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
        Arguments='-ExecutionPolicy Bypass -File "[INSTALLFOLDER]manage-agent.ps1" open-logs'
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\RemoteTerminalCloudAgent" Name="StartMenuShortcuts" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!--
      SetProperty passes RTC_REG_TOKEN as CustomActionData to the deferred WriteConfig action.
    -->
    <SetProperty Id="WriteConfig" Value="[RTC_REG_TOKEN]"
                 Before="WriteConfig" Sequence="execute" />
    <CustomAction Id="WriteConfig" Directory="PROGRAMDATA_AGENT"
      Execute="deferred" Impersonate="no" Return="check"
      ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]write-config.ps1&quot;" />

    <CustomAction Id="StopExistingService" Directory="INSTALLFOLDER"
      Execute="deferred" Impersonate="no" Return="ignore"
      ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]stop-service.ps1&quot; -InstallRoot &quot;[INSTALLFOLDER]&quot;" />

    <CustomAction Id="InstallService" Directory="INSTALLFOLDER"
      Execute="deferred" Impersonate="no" Return="check"
      ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install-service.ps1&quot;" />

    <CustomAction Id="UninstallService" Directory="INSTALLFOLDER"
      Execute="deferred" Impersonate="no" Return="ignore"
      ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]uninstall-service.ps1&quot;" />

    <InstallExecuteSequence>
      <Custom Action="StopExistingService" Before="InstallFiles">Installed</Custom>
      <Custom Action="WriteConfig" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="InstallService" After="WriteConfig">NOT Installed</Custom>
      <Custom Action="UninstallService" Before="RemoveFiles">Installed AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

  </Package>
</Wix>
