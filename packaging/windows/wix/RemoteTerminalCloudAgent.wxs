<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Remote Terminal Cloud Agent"
    Manufacturer="Remote Terminal Cloud"
    Version="0.1.0"
    UpgradeCode="A7A32B15-4E12-4DAB-8B9A-3C91F275AE60"
    InstallerVersion="500"
    Scope="perMachine"
    Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Remote Terminal Cloud Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- UI: fully custom flow defined in AgentConfigDlg.wxs -->
    <UIRef Id="AgentUI" />

    <!-- Secure properties so deferred CustomActions can read them via CustomActionData -->
    <Property Id="RTC_SERVER_URL" Value="" Secure="yes" />
    <Property Id="RTC_REG_TOKEN" Value="" Secure="yes" Hidden="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Remote Terminal Cloud Agent">
        <Directory Id="SERVICEFOLDER" Name="service" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="PROGRAMDATA_AGENT" Name="RemoteTerminalCloudAgent">
        <Directory Id="PROGRAMDATA_AGENT_LOGS" Name="logs" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Remote Terminal Cloud Agent" Level="1">
      <ComponentGroupRef Id="AgentFiles" />
      <ComponentRef Id="ProgramDataDirectoryComponent" />
      <ComponentRef Id="ProgramDataConfigComponent" />
      <ComponentRef Id="ProgramDataLogsDirectoryComponent" />
      <ComponentRef Id="ServiceWrapperComponent" />
    </Feature>

    <ComponentGroup Id="AgentFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.AgentBuildRoot)\dist\**" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\install-service.ps1" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\uninstall-service.ps1" />
      <Files Include="$(var.AgentBuildRoot)\packaging\windows\write-config.ps1" />
      <Files Include="$(var.AgentBuildRoot)\runtime\node.exe" />
    </ComponentGroup>

    <Component Id="ProgramDataDirectoryComponent" Directory="PROGRAMDATA_AGENT" Guid="E5D1A49D-ED8A-43E6-B70A-171D362BF04D">
      <CreateFolder />
    </Component>

    <Component Id="ProgramDataConfigComponent" Directory="PROGRAMDATA_AGENT" Guid="A0DF38D1-6925-4553-8E83-4C6774B664A7">
      <File Id="ProgramDataConfigFile" Source="$(var.AgentBuildRoot)\packaging\windows\agent.config.json" Name="config.json" KeyPath="yes" />
    </Component>

    <Component Id="ProgramDataLogsDirectoryComponent" Directory="PROGRAMDATA_AGENT_LOGS" Guid="2D4D1C5C-111D-4F93-B680-85BA6C4CE355">
      <CreateFolder />
    </Component>

    <!-- WinSW wrapper: files only, service lifecycle managed by PS scripts -->
    <Component Id="ServiceWrapperComponent" Directory="SERVICEFOLDER" Guid="A9D91CF9-43F6-4227-934B-988D53A4887D">
      <File Id="RemoteTerminalCloudAgentServiceExe" Source="$(var.AgentBuildRoot)\service\RemoteTerminalCloudAgentService.exe" KeyPath="yes" />
      <File Id="RemoteTerminalCloudAgentServiceXml" Source="$(var.AgentBuildRoot)\service\RemoteTerminalCloudAgentService.xml" />
    </Component>

    <!--
      WriteConfig: patch config.json with user input before the service starts.
      SetProperty feeds [RTC_SERVER_URL]|[RTC_REG_TOKEN] into CustomActionData so the
      deferred (elevated, no UI) CA can read it via $env:CustomActionData.
    -->
    <SetProperty Id="WriteConfig" Value="[RTC_SERVER_URL]|[RTC_REG_TOKEN]"
                 Before="WriteConfig" Sequence="execute" />
    <CustomAction Id="WriteConfig" Directory="PROGRAMDATA_AGENT"
      Execute="deferred" Impersonate="no" Return="check"
      ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]write-config.ps1&quot;" />

    <CustomAction Id="InstallService" Directory="INSTALLFOLDER"
      Execute="deferred" Impersonate="no" Return="check"
      ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install-service.ps1&quot;" />

    <CustomAction Id="UninstallService" Directory="INSTALLFOLDER"
      Execute="deferred" Impersonate="no" Return="ignore"
      ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]uninstall-service.ps1&quot;" />

    <InstallExecuteSequence>
      <Custom Action="WriteConfig" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="InstallService" After="WriteConfig">NOT Installed</Custom>
      <Custom Action="UninstallService" Before="RemoveFiles">Installed AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

  </Package>
</Wix>
