<service>
  <id>RemoteTerminalCloudAgent</id>
  <name>Remote Terminal Cloud Agent</name>
  <description>Outbound remote terminal agent service.</description>
  <executable>%BASE%\..\runtime\node.exe</executable>
  <arguments>%BASE%\..\dist\index.js</arguments>
  <workingdirectory>%BASE%\..</workingdirectory>
  <env name="RTC_CONFIG_FILE" value="%ProgramData%\RemoteTerminalCloudAgent\config.json" />
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
    <pattern>yyyyMMdd</pattern>
    <autoRollAtTime>00:00:00</autoRollAtTime>
  </log>
  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="20 sec" />
  <resetfailure>1 hour</resetfailure>
</service>